{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Story Generation Workflow Environment Variables",
  "type": "object",
  "required": [
    "NODE_ENV",
    "PORT",
    "DB_HOST",
    "DB_PORT",
    "DB_USER",
    "DB_PASSWORD",
    "DB_NAME",
    "GOOGLE_CLOUD_PROJECT_ID",
    "GOOGLE_CLOUD_REGION",
    "STORAGE_BUCKET_NAME"
  ],
  "properties": {
    "NODE_ENV": {
      "type": "string",
      "enum": ["development", "staging", "production"],
      "description": "Node.js environment"
    },
    "PORT": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Port for the HTTP server"
    },
    "DB_HOST": {
      "type": "string",
      "description": "Database host"
    },
    "DB_PORT": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Database port"
    },
    "DB_USER": {
      "type": "string",
      "description": "Database user"
    },
    "DB_PASSWORD": {
      "type": "string",
      "description": "Database password"
    },
    "DB_NAME": {
      "type": "string",
      "description": "Database name"
    },
    "DB_SSL": {
      "type": "string",
      "enum": ["true", "false"],
      "description": "Enable SSL for database connection"
    },
    "GOOGLE_CLOUD_PROJECT_ID": {
      "type": "string",
      "description": "Google Cloud Project ID"
    },
    "GOOGLE_CLOUD_REGION": {
      "type": "string",
      "description": "Google Cloud Region"
    },
    "STORAGE_BUCKET_NAME": {
      "type": "string",
      "description": "Google Cloud Storage bucket name for generated content"
    },
    "IMAGE_GENERATION_MODEL": {
      "type": "string",
      "description": "Model for image generation (optional)"
    },
    "LOG_LEVEL": {
      "type": "string",
      "enum": ["error", "warn", "info", "debug"],
      "description": "Logging level"
    },
    "OPENAI_IMAGE_MAX_RETRIES": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "(Optional) Max retry attempts for image generation when response lacks usable image data. Default 2"
    },
    "OPENAI_IMAGE_EDIT_MAX_RETRIES": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "(Optional) Override retry attempts specifically for image edit operations. Falls back to OPENAI_IMAGE_MAX_RETRIES if unset"
    },
    "OPENAI_IMAGE_RETRY_DELAY_MS": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "(Optional) Delay in milliseconds between retry attempts for image generation/edit. Default 1500"
    },
    "OPENAI_IMAGE_PREFER_BASE64": {
      "type": "string",
      "enum": ["true", "false"],
      "description": "(Optional) If true (default), URL-only results trigger retries to obtain base64 image data"
    }
  },
  "additionalProperties": false
}
