{
  "type": "object",
  "properties": {
    "story": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "plotDescription": { "type": "string" },
        "synopsis": { "type": "string" },
        "place": { "type": "string" },
        "additionalRequests": { "type": "string" },
        "targetAudience": {
          "type": "string",
          "enum": [
            "children_0-2",
            "children_3-6",
            "children_7-10",
            "children_11-14",
            "young_adult_15-17",
            "adult_18+",
            "all_ages"
          ]
        },
        "novelStyle": {
          "type": "string",
          "enum": [
            "adventure",
            "fantasy",
            "mystery",
            "romance",
            "science_fiction",
            "historical",
            "contemporary",
            "fairy_tale",
            "comedy",
            "drama",
            "horror",
            "thriller",
            "biography",
            "educational",
            "poetry",
            "sports_adventure"
          ]
        },
        "graphicalStyle": {
          "type": "string",
          "enum": [
            "cartoon",
            "realistic",
            "watercolor",
            "digital_art",
            "hand_drawn",
            "minimalist",
            "vintage",
            "comic_book",
            "euro_comic_book",
            "anime",
            "pixar_style",
            "disney_style",
            "sketch",
            "oil_painting",
            "colored_pencil"
          ]
        },
        "literaryPersona": {
          "type": "string",
          "enum": [
            "storyteller",
            "adventurous-narrator",
            "fun-reporter",
            "friendly-educator",
            "institutional-chronicler",
            "pub-buddy-narrator",
            "classic-novelist",
            "noir-investigator",
            "whimsical-poet",
            "scifi-analyst",
            "folklore-traditionalist"
          ]
        },
        "storyLanguage": {
          "type": "string",
          "maxLength": 5,
          "description": "BCP-47 locale code of the story language (e.g. en-US, pt-PT, es-ES, fr-FR, de-DE). Max 5 chars. Never a language name."
        },
        "coverReferenceImages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths (the `path` field from the provided input image metadata) of `photo`-type input images that are visually relevant to depict on the FRONT cover (e.g. the main subject/scenery). Empty array if none apply."
        },
        "backCoverReferenceImages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths of `photo`-type input images relevant to the BACK cover. Empty array if none apply."
        }
      },
      "required": ["title", "plotDescription"]
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "characterId": { "type": ["string", "null"] },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "boy",
              "girl",
              "man",
              "woman",
              "person",
              "dog",
              "cat",
              "bird",
              "other_animal",
              "dragon",
              "elf_fairy_mythical",
              "robot_cyborg",
              "alien_extraterrestrial",
              "other_creature",
              "other"
            ]
          },
          "age": {
            "type": "string",
            "enum": [
              "infant",
              "toddler",
              "preschool",
              "school_age",
              "teenage",
              "emerging_adult",
              "seasoned_adult",
              "midlife_mentor",
              "elder",
              "youngling",
              "adult",
              "senior"
            ]
          },
          "traits": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "string",
              "enum": [
                "adaptable",
                "brave",
                "compassionate",
                "courageous",
                "curious",
                "decisive",
                "empathetic",
                "generous",
                "honest",
                "imaginative",
                "loyal",
                "optimistic",
                "patient",
                "practical",
                "pragmatic",
                "resourceful",
                "self-disciplined",
                "sincere",
                "witty",
                "kind",
                "conscientious",
                "energetic",
                "arrogant",
                "callous",
                "cowardly",
                "cynical",
                "deceitful",
                "impulsive",
                "jealous",
                "lazy",
                "manipulative",
                "moody",
                "reckless",
                "selfish",
                "vengeful",
                "aloof",
                "blunt",
                "cautious",
                "methodical"
              ]
            }
          },
          "characteristics": { "type": "string" },
          "physicalDescription": { "type": "string" },
          "sourceImagePath": {
            "type": ["string", "null"],
            "description": "If this character is derived from a person/animal detected in a user-uploaded input photo, set this to the exact `path` of that image (from the provided image metadata). Otherwise null."
          },
          "sourceCharacterIndex": {
            "type": ["integer", "null"],
            "description": "When sourceImagePath is set, the zero-based index of the matching entry in that image's `characters` array. Otherwise null."
          },
          "role": {
            "type": "string",
            "enum": [
              "protagonist",
              "antagonist",
              "supporting",
              "mentor",
              "comic_relief",
              "love_interest",
              "sidekick",
              "narrator",
              "other"
            ]
          }
        },
        "required": ["name"]
      }
    },
    "thought_process": {
      "type": "string",
      "description": "Your internal reasoning and plan for this story structure. Analyze the user's input, detect the language, and plan the story beats and character archetypes before generating the structured JSON."
    }
  },
  "required": ["story", "characters", "thought_process"]
}

