{
  "name": "story-generation-workflow",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias && copyfiles -u 1 \"src/**/*.json\" \"src/**/*.html\" \"src/**/*.icc\" \"src/**/*.mp3\" dist/",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "logs": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\logs.ps1",
    "logs:tail": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\logs.ps1 -Follow",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx -r dotenv/config ./src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "workflows-db:generate": "drizzle-kit generate --config=drizzle.workflows.config.ts",
    "workflows-db:migrate": "tsx -r dotenv/config ./src/db/migrate-workflows.ts",
    "workflows-db:push": "drizzle-kit push --config=drizzle.workflows.config.ts",
    "workflows-db:studio": "drizzle-kit studio --config=drizzle.workflows.config.ts",
    "sync-schema": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sync-schema.ps1",
    "docker:build": "docker build -t story-generation-workflow .",
    "docker:run": "docker run -p 8080:8080 story-generation-workflow",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy.ps1",
    "deploy:fast": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy.ps1 -Fast",
    "setup-secrets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-secrets.ps1",
    "check-secrets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check-secrets.ps1",
    "env:validate": "tsx src/config/validate-env.ts",
    "env:parity": "tsx scripts/check-env-parity.ts",
    "get-logs": "gcloud logging read \"resource.type=cloud_run_revision AND resource.labels.service_name=story-generation-workflow\" --limit=30 --format=\"json\" --project=oceanic-beach-460916-n5",
    "schema:sync": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sync-schema.ps1",
    "schema:sync-dry": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sync-schema.ps1 -DryRun",
    "schema:sync-verbose": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sync-schema.ps1 -Verbose",
    "clean": "rimraf dist",
    "lint:bash": "bash ./scripts/lint.sh",
    "i18n:keys": "tsx scripts/check-i18n.ts keys de-DE",
    "i18n:parity": "tsx scripts/check-i18n.ts parity de-DE"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/workflows": "^5.1.1",
    "@google/genai": "^2.7.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "hyphen": "^1.14.1",
    "node-html-parser": "^7.1.0",
    "openai": "^6.41.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "puppeteer": "^25.1.0",
    "sharp": "^0.34.5",
    "tmp": "^0.2.7",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/hyphen": "^1.14.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/supertest": "^7.2.0",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@img/sharp-linux-arm64": "0.34.5",
    "@img/sharp-linux-x64": "0.34.5"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
